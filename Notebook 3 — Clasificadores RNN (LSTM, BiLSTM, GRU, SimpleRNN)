l Contrato de Datos JSON"],"metadata":{"id":"kQxuQJItJCtD"}},{"cell_type":"code","source":["# ==============================================================================\n","# 5. CONTRATO DE DATOS JSON PARA EL FRONTEND\n","# ==============================================================================\n","# Helper para definir la seГ±al del semГЎforo basada en la probabilidad final\n","def obtener_senal(probabilidad):\n","    if probabilidad > 0.65: return \"BUY\"\n","    elif probabilidad < 0.35: return \"SELL\"\n","    return \"HOLD\"\n","\n","contrato_rnns = {\n","    \"ticker\": ticker,\n","    \"ultima_actualizacion\": pd.Timestamp.now().strftime('%Y-%m-%d %H:%M:%S'),\n","    \"modelos\": {\n","        \"lstm\": {\n","            \"metricas\": resultados[\"lstm\"],\n","            \"probabilidad_maГ±ana\": ultimas_predicciones[\"lstm\"],\n","            \"senal\": obtener_senal(ultimas_predicciones[\"lstm\"])\n","        },\n","        \"bilstm\": {\n","            \"metricas\": resultados[\"bilstm\"],\n","            \"probabilidad_maГ±ana\": ultimas_predicciones[\"bilstm\"],\n","            \"senal\": obtener_senal(ultimas_predicciones[\"bilstm\"])\n","        },\n","        \"gru\": {\n","            \"metricas\": resultados[\"gru\"],\n","            \"probabilidad_maГ±ana\": ultimas_predicciones[\"gru\"],\n","            \"senal\": obtener_senal(ultimas_predicciones[\"gru\"])\n","        },\n","        \"simplernn\": {\n","            \"metricas\": resultados[\"simplernn\"],\n","            \"probabilidad_maГ±ana\": ultimas_predicciones[\"simplernn\"],\n","            \"senal\": obtener_senal(ultimas_predicciones[\"simplernn\"])\n","        }\n","    }\n","}\n","\n","# Guardar archivo local\n","with open('datos_rnns_clf.json', 'w') as f:\n","    json.dump(contrato_rnns, f, indent=4)\n","\n","print(\"Archivo 'datos_rnns_clf.json' generado con Г©xito con la estructura requerida.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Uc2HxRDcJEBr","executionInfo":{"status":"ok","timestamp":1781966332597,"user_tz":300,"elapsed":18,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"81ad7256-6b32-4e46-95a0-6bd0fe7ebba7"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Archivo 'datos_rnns_clf.json' generado con Г©xito con la estructura requerida.\n"]}]}]}