{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOS5HWjUR3+4pg+WB3V/Bk/"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["Celda 1: Inicialización"],"metadata":{"id":"KnKfyLKKJNfm"}},{"cell_type":"code","source":["# ==============================================================================\n","# 1. INSTALACIÓN E IMPORTACIÓN DE LIBRERÍAS (REGRESIÓN)\n","# ==============================================================================\n","!pip install yfinance tensorflow scikit-learn --quiet\n","\n","import numpy as np\n","import pandas as pd\n","import yfinance as yf\n","import json\n","from sklearn.preprocessing import MinMaxScaler\n","from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n","import tensorflow as tf\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import Dense, LSTM, Dropout\n","\n","np.random.seed(42)\n","tf.random.set_seed(42)\n","print(\"Entorno de regresión configurado.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lgwQNZ-gJgL6","executionInfo":{"status":"ok","timestamp":1781810040008,"user_tz":300,"elapsed":20993,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"d4f4dd00-3e3f-476e-ea7b-7accb4071b02"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Entorno de regresión configurado.\n"]}]},{"cell_type":"markdown","source":["Celda 2: Preparación Estricta de Ventanas de 60 días"],"metadata":{"id":"BinN1egUJidj"}},{"cell_type":"code","source":["# ==============================================================================\n","# 2. INGESTA Y ESTRUCTURACIÓN DE VENTANAS SLIDING (60 DÍAS)\n","# ==============================================================================\n","ticker = \"FSM\"\n","datos_reg = yf.download(ticker, period=\"2y\", interval=\"1d\")\n","precios_reales = datos_reg['Close'].values.reshape(-1, 1)\n","\n","# Escalado univariado (Precios de Cierre)\n","scaler_reg = MinMaxScaler(feature_range=(0, 1))\n","precios_scaled = scaler_reg.fit_transform(precios_reales)\n","\n","VENTANA_REG = 60\n","X_reg, y_reg = [], []\n","\n","for i in range(len(precios_scaled) - VENTANA_REG):\n","    X_reg.append(precios_scaled[i : i + VENTANA_REG])\n","    y_reg.append(precios_scaled[i + VENTANA_REG])\n","\n","X_reg, y_reg = np.array(X_reg), np.array(y_reg)\n","\n","# Split 80/20 temporal\n","split_reg = int(len(X_reg) * 0.8)\n","X_train_r, X_test_r = X_reg[:split_reg], X_reg[split_reg:]\n","y_train_r, y_test_r = y_reg[:split_reg], y_reg[split_reg:]\n","\n","print(f\"X_train_r shape: {X_train_r.shape} | X_test_r shape: {X_test_r.shape}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LbQ2M8J7JkcT","executionInfo":{"status":"ok","timestamp":1781810040388,"user_tz":300,"elapsed":367,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"8d140775-8acc-4ab9-8472-7d26f707e468"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_2575/3205563323.py:5: FutureWarning: YF.download() has changed argument auto_adjust default to True\n","  datos_reg = yf.download(ticker, period=\"2y\", interval=\"1d\")\n","[*********************100%***********************]  1 of 1 completed"]},{"output_type":"stream","name":"stdout","text":["X_train_r shape: (353, 60, 1) | X_test_r shape: (89, 60, 1)\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"markdown","source":["Celda 3: Red LSTM Profunda y Evaluación de Errores"],"metadata":{"id":"CK6njMteJmGj"}},{"cell_type":"code","source":["# ==============================================================================\n","# 3. ENTRENAMIENTO DE LA NEURONAL LSTM DE REGRESIÓN\n","# ==============================================================================\n","model_reg = Sequential([\n","    LSTM(64, return_sequences=True, input_shape=(X_train_r.shape[1], 1)),\n","    Dropout(0.2),\n","    LSTM(32, return_sequences=False),\n","    Dropout(0.2),\n","    Dense(16, activation='relu'),\n","    Dense(1, activation='linear')  # Salida lineal continua para precios en USD\n","])\n","\n","model_reg.compile(optimizer='adam', loss='mean_squared_error')\n","print(\"Entrenando Regresor LSTM (100 épocas)...\")\n","model_reg.fit(X_train_r, y_train_r, epochs=100, batch_size=32, verbose=0)\n","\n","# Predicciones sobre el set de prueba\n","pred_scaled = model_reg.predict(X_test_r)\n","pred_usd = scaler_reg.inverse_transform(pred_scaled).flatten()\n","y_test_usd = scaler_reg.inverse_transform(y_test_r).flatten()\n","\n","# Cálculo estricto de Métricas\n","rmse = np.sqrt(mean_squared_error(y_test_usd, pred_usd))\n","mae = mean_absolute_error(y_test_usd, pred_usd)\n","r2 = r2_score(y_test_usd, pred_usd)\n","rmse_porcentaje = (rmse / np.mean(y_test_usd)) * 100\n","\n","print(f\"\\nMétricas del Modelo:\\n- RMSE: {rmse:.4f} USD\\n- MAE: {mae:.4f} USD\\n- R² Score: {r2:.4f}\\n- RMSE %: {rmse_porcentaje:.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"C-yWpRpCJpPk","executionInfo":{"status":"ok","timestamp":1781810119520,"user_tz":300,"elapsed":79103,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"e67b6de5-8bcc-4a3e-b1ea-59f7d9373f63"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["Entrenando Regresor LSTM (100 épocas)...\n","\u001b[1m3/3\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 149ms/step\n","\n","Métricas del Modelo:\n","- RMSE: 0.7015 USD\n","- MAE: 0.5183 USD\n","- R² Score: 0.6680\n","- RMSE %: 6.81%\n"]}]},{"cell_type":"markdown","source":["Celda 4: Proyección Futura (30 días) y Bandas Matemáticas ($\\pm 1.96 \\times RMSE$)"],"metadata":{"id":"S0ienslQJrcr"}},{"cell_type":"code","source":["# ==============================================================================\n","# 4. PRONÓSTICO AUTOREGRESIVO A FUTURO (30 DÍAS)\n","# ==============================================================================\n","proyeccion_dias = 30\n","# Comenzamos con la última ventana de prueba disponible\n","ultima_ventana = precios_scaled[-VENTANA_REG:].tolist()\n","predicciones_futuras_scaled = []\n","\n","for _ in range(proyeccion_dias):\n","    entrada_modelo = np.array([ultima_ventana[-VENTANA_REG:]])\n","    pred_nueva_scaled = model_reg.predict(entrada_modelo, verbose=0)[0][0]\n","    predicciones_futuras_scaled.append(pred_nueva_scaled)\n","    # Alimentar recursivamente la predicción al final de la ventana\n","    ultima_ventana.append([pred_nueva_scaled])\n","\n","# Invertir el escalado de la predicción futura\n","precios_futuros_usd = scaler_reg.inverse_transform(np.array(predicciones_futuras_scaled).reshape(-1, 1)).flatten()\n","\n","# Generación matemática de Bandas de Confianza\n","banda_superior = precios_futuros_usd + (1.96 * rmse)\n","banda_inferior = precios_futuros_usd - (1.96 * rmse)\n","\n","print(\"Proyección futura calculada con éxito.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SlA2uwYnJs5k","executionInfo":{"status":"ok","timestamp":1781810123214,"user_tz":300,"elapsed":3689,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"274b4091-70d6-4774-879e-a564a3baad08"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Proyección futura calculada con éxito.\n"]}]},{"cell_type":"markdown","source":["Celda 5: Exportación del JSON del Regresor"],"metadata":{"id":"g3Sm-5nLJup0"}},{"cell_type":"code","source":["# ==============================================================================\n","# 5. CONTRATO DE DATOS JSON (REGRESIÓN)\n","# ==============================================================================\n","fechas_reales = datos_reg.index[-len(y_test_usd):].strftime('%Y-%m-%d').tolist()\n","fechas_futuras = pd.date_range(start=datos_reg.index[-1] + pd.Timedelta(days=1), periods=proyeccion_dias).strftime('%Y-%m-%d').tolist()\n","\n","contrato_lstm = {\n","    \"ticker\": ticker,\n","    \"metricas_error\": {\n","        \"rmse_usd\": round(float(rmse), 4),\n","        \"rmse_porcentaje\": round(float(rmse_porcentaje), 2),\n","        \"mae_usd\": round(float(mae), 4),\n","        \"r2_score\": round(float(r2), 4)\n","    },\n","    \"historico_validacion\": [\n","        {\"fecha\": f, \"real\": round(float(r), 4), \"predicho\": round(float(p), 4)}\n","        for f, r, p in zip(fechas_reales, y_test_usd, pred_usd)\n","    ],\n","    \"proyeccion_futura\": [\n","        {\n","            \"fecha\": f,\n","            \"prediccion_usd\": round(float(p), 4),\n","            \"banda_min\": round(float(b_min), 4),\n","            \"banda_max\": round(float(b_max), 4)\n","        }\n","        for f, p, b_min, b_max in zip(fechas_futuras, precios_futuros_usd, banda_inferior, banda_superior)\n","    ]\n","}\n","\n","with open('datos_lstm_reg.json', 'w') as f:\n","    json.dump(contrato_lstm, f, indent=4)\n","\n","print(\"Archivo 'datos_lstm_reg.json' exportado correctamente.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lrmY2KZ6JvzM","executionInfo":{"status":"ok","timestamp":1781810123250,"user_tz":300,"elapsed":20,"user":{"displayName":"MARIANO ABEL CRUZ CHAVEZ","userId":"03770206601413230171"}},"outputId":"7ab955dd-bc35-4aec-823c-849f809605d9"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Archivo 'datos_lstm_reg.json' exportado correctamente.\n"]}]}]}